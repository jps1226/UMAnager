 val[0];\nvar page_stat = val[1];\nvar location_url = '';\nif( page_stat == 'result' ){\nlocation_url = \"/mydata/race_yoso_list.html?race_id=\"+race_id;// 結果\n}else{// page_stat=\"shutuba\"\nlocation_url = \"/bet/shutuba.html?mode=init&race_id=\"+race_id;// 出馬表\n}\n$(\"#navi_race_page_\"+race_id+\"-\"+page_stat).attr(\"href\", location_url);\n//window.location.href = location_url;// 2018.7.20 検証のためコメントアウト\n});\n// 自分の投票内容(レースごとの投票有無)を取得し描画\nfunction get_my_bet_data_for_navi( _ary_race_id, _callback ){\nconsole.log('get_my_bet_data_for_navi');\nvar url = '';\nvar _data = { action : 'my_bet_data' };\n_data.input  = 'UTF-8';\n_data.output = 'jsonp';\n_data.race_id_list = _ary_race_id;\n$.ajax({\ntype: \"GET\",\nurl: _action_api_url_bet_race_for_navi,\ndata: _data,\ndataType : 'jsonp',\nsuccess: function(json) {\nif(json.status == 'OK'){\nif(undefined != _callback){\n// 描画用のコールバック関数\n_callback( json );\n}\n}\n},\nerror: function(XMLHttpRequest, textStatus, errorThrown) {\nconsole.log('textStatus='+textStatus);\n}\n});\n}\n// 賞品付きアイコン表示\nvar prize_race_id_list = ',201903030411,201904010211,201905020311,201905040111,201905040211,201905040308,201905040511,201905040611,201905040811,201905040911,201905050111,201905050211,201905050311,201905050511,201905050811,201906040111,201906040211,201906040511,201906040711,201906040911,201906050111,201906050411,201906050511,201906050710,201906050811,201906050911,201907040211,201907040311,201908030311,201908040211,201908040411,201908040711,201908040811,201908050111,201908050211,201908050308,201908050311,201908050411,201908050611,201908050711,201908050812,201909040211,201909040308,201909040411,201909040711,201909040811,201909050111,201909050411,201909050611,201909050711,201930101011,201930103111,201935101411,201942091211,201942110408,201942110409,201942110410,201942112810,201943092311,201943121111,201944100211,201944100311,201944122910,201945121811,201946100111,201948121911,201950112710,201950122710,2019B1091405,2019C8100604,2019G4110507,