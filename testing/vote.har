          "content": {
            "size": 7323,
            "mimeType": "application/javascript",
            "text": "//------------------------------------------------------------\n// レースごとの投票数取得し描画\nfunction get_race_bet_count( _ary_race_id, _callback )\n{\n  console.log('get_race_bet_count');\n  console.log('_action_api_url_bet_race: %s',_action_api_url_bet_race);\n\n  var url = '';\n  var _data = { action : 'bet_count' };\n  _data.input  = 'UTF-8';\n  _data.output = 'jsonp';\n  _data.race_id_list = _ary_race_id;\n\n  $.ajax({\n    type: \"GET\",\n    url: _action_api_url_bet_race,\n    data: _data,\n    dataType : 'jsonp',\n    success: function(json) {\n      if(json.status == 'OK'){\n        if(undefined != _callback){\n          // 描画用のコールバック関数\n          _callback( json, _ary_race_id );\n        }\n      }\n    },\n    error: function(XMLHttpRequest, textStatus, errorThrown) {\n      console.log('textStatus='+textStatus);\n    }\n  });\n}\n\n// レースごとの予想人数(投票数)を非同期に描画\nfunction callback_bet_count_show( json, _ary_race_id )\n{\n    var race_data = json.data;\n    for( var i = 0; i < _ary_race_id.length; i++ )\n    {\n        var race_id = _ary_race_id[i];\n        var race_bet_count = race_data[race_id];\n\n        // 予想人数：<span class=\"bet_count_レースID\"></span>に値を埋め込む\n        $(\".bet_count_\"+race_id).html( race_bet_count );\n    }\n}\n\n//------------------------------------------------------------\n// 自分の投票内容(レースごとの投票有無、的中有無、勝負レース有無)を取得し描画\nfunction get_my_bet_data( _ary_race_id, _callback )\n{\n  console.log('get_my_bet_data');\n  console.log('_action_api_url_bet_race: %s',_action_api_url_bet_race);\n\n  var url = '';\n  var _data = { action : 'my_bet_data' };\n  _data.input  = 'UTF-8';\n  _data.output = 'jsonp';\n  _data.race_id_list = _ary_race_id;\n\n  $.ajax({\n    type: \"GET\",\n    url: _action_api_url_bet_race,\n    data: _data,\n    dataType : 'jsonp',\n    success: function(json) {\n      if(json.status == 'OK'){\n        if(undefined != _callback){\n          // 描画用のコールバック関数\n          _callback( json, _ary_race_id );\n        }\n      }\n    },\n    error: function(XMLHttpRequest, textStatus, errorThrown) {\n      console.log('textStatus='+textStatus);\n    }\n  });\n}\n\n// 自分の投票内容(レースごとの投票有無、的中有無、勝負レース有無)を非同期に描画\nfunction callback_my_bet_data_show( json, _ary_race_id )\n{\n    var race_data = json.data;\n\n    for(var race_id in race_data){\n        console.log('race_id: %s %O',race_id,race_data[race_id]);\n\n        if('1' == race_data[race_id]['is_bet']){\n            // 投票済マーク\n            $('#is_bet_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['is_hit']){\n            // 的中マーク\n            $('#is_hit_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['is_change']){\n            // 予想変更マーク\n            $('#is_change_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['for_real']){\n            // 勝負マーク\n            $('#for_real_'+race_id).removeClass('disp_none');\n        }\n        if('0' == race_data[race_id]['recover']){\n            // 回収率ランキング除外フラグ\n            $('#recover_'+race_id).removeClass('disp_none');\n        }\n    }\n}\n\n//------------------------------------------------------------\n// 自分の投票内容(レースごとの投票有無、的中有無、勝負レース有無)を取得し描画(WIN5キング：5レース本命◎の的中)\nfunction get_my_win5_king_bet_data( _ary_race_id, _event_id, _callback )\n{\n  console.log('get_my_win5_king_bet_data');\n  console.log('_action_api_url_bet_race: %s',_action_api_url_bet_race);\n\n  var url = '';\n  var _data = { action : 'my_win5_king_bet_data' };\n  _data.input  = 'UTF-8';\n  _data.output = 'jsonp';\n  _data.race_id_list = _ary_race_id;\n  _data.event_id = _event_id;\n\n  $.ajax({\n    type: \"GET\",\n    url: _action_api_url_bet_race,\n    data: _data,\n    dataType : 'jsonp',\n    success: function(json) {\n      if(json.status == 'OK'){\n        if(undefined != _callback){\n          // 描画用のコールバック関数\n          _callback( json, _ary_race_id );\n        }\n      }\n    },\n    error: function(XMLHttpRequest, textStatus, errorThrown) {\n      console.log('textStatus='+textStatus);\n    }\n  });\n}\n\n// 自分の投票内容(レースごとの投票有無、的中有無、勝負レース有無)を非同期に描画(WIN5キング：5レース本命◎の的中)\nfunction callback_my_win5_king_bet_data_show( json, _ary_race_id )\n{\n    var race_data = json.data;\n\n    for(var race_id in race_data){\n        console.log('race_id: %s %O',race_id,race_data[race_id]);\n\n        if('1' == race_data[race_id]['is_bet']){\n            // 投票済マーク\n            $('#is_bet_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['is_hit']){\n            // 的中マーク\n            $('#is_hit_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['is_change']){\n            // 予想変更マーク\n            $('#is_change_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['for_real']){\n            // 勝負マーク\n            $('#for_real_'+race_id).removeClass('disp_none');\n        }\n        if('0' == race_data[race_id]['recover']){\n            // 回収率ランキング除外フラグ\n            $('#recover_'+race_id).removeClass('disp_none');\n        }\n    }\n}\n\n//------------------------------------------------------------\n// 自分の投票内容(レースごとの投票有無、的中有無、勝負レース有無)を取得し描画(重賞キング：1レース印◎◯▲の的中)\nfunction get_my_grade_king_bet_data( _ary_race_id, _event_id, _callback )\n{\n  console.log('get_my_grade_king_bet_data');\n  console.log('_action_api_url_bet_race: %s',_action_api_url_bet_race);\n\n  var url = '';\n  var _data = { action : 'my_grade_king_bet_data' };\n  _data.input  = 'UTF-8';\n  _data.output = 'jsonp';\n  _data.race_id_list = _ary_race_id;\n  _data.event_id = _event_id;\n\n  $.ajax({\n    type: \"GET\",\n    url: _action_api_url_bet_race,\n    data: _data,\n    dataType : 'jsonp',\n    success: function(json) {\n      if(json.status == 'OK'){\n        if(undefined != _callback){\n          // 描画用のコールバック関数\n          _callback( json, _ary_race_id );\n        }\n      }\n    },\n    error: function(XMLHttpRequest, textStatus, errorThrown) {\n      console.log('textStatus='+textStatus);\n    }\n  });\n}\n\n// 自分の投票内容(レースごとの投票有無、的中有無、勝負レース有無)を非同期に描画(重賞キング：1レース印◎◯▲の的中)\nfunction callback_my_grade_king_bet_data_show( json, _ary_race_id )\n{\n    var race_data = json.data;\n\n    for(var race_id in race_data){\n        console.log('race_id: %s %O',race_id,race_data[race_id]);\n\n        if('1' == race_data[race_id]['is_bet']){\n            // 投票済マーク\n            $('#is_bet_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['is_hit']){\n            // 的中マーク\n            $('#is_hit_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['is_change']){\n            // 予想変更マーク\n            $('#is_change_'+race_id).removeClass('disp_none');\n        }\n        if('1' == race_data[race_id]['for_real']){\n            // 勝負マーク\n            $('#for_real_'+race_id).removeClass('disp_none');\n        }\n        if('0' == race_data[race_id]['recover']){\n            // 回収率ランキング除外フラグ\n            $('#recover_'+race_id).removeClass('disp_none');\n        }\n    }\n}"
