r: function( XMLHttpRequest, textStatus, errorThrown){\nconsole.log('XMLHttpRequest: %O',XMLHttpRequest);\nconsole.log('textStatus: %O',textStatus);\n}\n});\n});\nfunction show_user( data ){\nvar is_stage = data.is_stage;\nvar is_user  = data.is_user;\nvar is_alert = data.is_alert;\nvar is_sp    = data.is_sp;\nvar nickname = data.nickname;\nvar user_img = data.user_img;\nif(is_sp) {\n$('.sp_nk_btn').show();\n}\nif(! is_stage) {\n$('.header_stage_area').remove();\n}\nif(is_user){\n//ログイン中\n$('.login_show').show();\n$('.header_nickname').html( nickname + 'さん' );\n$('.header_user_img').attr('src', user_img)\nif(is_alert) {\n$('.Alert_New').show();\n}\n} else {\n//未ログイン\n$('.no_login_show').show();\n$('.login_show').remove();\n}\n}\n</script>\n<!-- block=netkeiba_header_sp (d) -->\n\n<!-- block=orepro_navi (d) -->\n<div class=\"Navi_Contents\">\n<nav id=\"Orepro_Navi\">\n<a href=\"/orepro/top.html\" id=\"a-orepro\"><img src=\"https://cdn.netkeiba.com/img.orepro//common/img/orepro/top_btn_icon.png\">俺プロ</a>\n</nav>\n</div>\n<script>\n'use strict'\n$(function(){\nvar navi_map = {\norepro: 'a-orepro',\nbet2: 'a-bet2',\nyoso: 'a-yoso',\nranking: 'a-ranking',\nmydata: 'a-mydata',\nsetting: 'a-setting',\ntutorial: 'a-orepro',\n};\nvar query = $('<a href=\"' + window.location.href + '\"></a>');\nvar dir = dirname( query[0].pathname );\ndir = dir.replace(/\\u002f/g, '');\nconsole.log('dir: %s',dir);\nif(navi_map[dir]){\nconsole.log('id: %s',navi_map[dir]);\n$('#'+navi_map[dir]).toggleClass('navi_active');\n}\n//------------------------------------------------------------\nfunction dirname(path) {\nreturn path.replace(/\\\\/g,'/').replace(/\\/[^\\/]*$/, '');;\n}\n});\n</script>\n<!-- block=race_feed (d) -->\n<div id=\"nk_alert\"></div>\n<audio id=\"audio_play\" preload=\"auto\">\n<source src=\"https://cdn.netkeiba.com/img.orepro//common/sound/alert_sample.mp3\" type=\"audio/mp3\">\n</audio>\n<script>\n// $Id$\n\"use strict\"\n/*\n* 通知関連\n*/\n$(function(){\nvar api_url = 'https://cdn.netkeiba.com/img.orepro//nkfeed/api_get_nkfeed.html';\nvar msg_id = '';\nvar msg = '';\n//------------------------------------------------------------\nvar check_interval = 60 * 1000 * 3;\t// 3 minitus\nvar timer_count = 0;\nfeed_check();\nsetInterval(function(){\nfeed_check();\n}, check_interval);\n// 通知ダイアログの範囲外をクリック\n$(document).on('click touchend', function(event) {\nif('' == msg_id){\nreturn;\n}\n//\t if (!$(event.target).closest('#nk_alert').length) {\n//\t     console.error('other click -> close');\n//\t     $('#nk_alert').html('');\t// close\n//\t     remove_msg(msg_id);\t// 既読=削除\n//\t     msg_id = '';\n//\t }\n});\n// 通知BOX内をクリックしたら既読\n$(document).on('click', '#Alert_Box', function() {\nif('' == msg_id){\nreturn;\n}\nconsole.error('#Alert_Box');\n$('#nk_alert').html('');\t// close\nremove_msg(msg_id);\t// 既読=削除\nmsg_id = '';\n});\n//------------------------------------------------------------\nfunction feed_check()\n{\nconsole.log('feed_check');\nvar dt = new Date();\nvar hms = dt.getHours()+':'+dt.getMinutes()+':'+dt.getSeconds();\nconsole.log('feed_check %s',hms);\napi_nkfeed(api_url, 'get', {}, function(data){\nconsole.log('data: %O',data);\nif('OK' == data.status){\nif('' == data.data){\n// empty data\nreturn false;\n}\nmsg_id = data.data.msg_id;\nmsg = data.data.msg;\n//\t\t $('#audio_play')[0].currentTime = 0;\n//\t\t $('#audio_play')[0].play();\nsetTimeout(function(){\n$('#nk_alert').html( msg );\nalert_slide(function( data ){\n$('#nk_alert').html('');\t// close\nremove_msg(msg_id);\t// 既読=削除\nmsg_id = '';\n});\n},1000);\n}\n});\n}\n//------------------------------------------------------------\nfunction alert_slide( fn )\n{\nvar box_w =$('.Text_Mask').width();\nvar text_w = $('.Text').width();\n//マーキーさせる秒数計算\nvar w_c = $('.Text').text().length;\nw_c = (w_c * 0.2) * 1000;\n//上から出てくる\n$('#Alert_Box').animate({\n'top':2\n//上から出たら文字マーキー\n},800,function(){\n$('.Text').fadeIn().delay(800).animate({\n'left':'-' + text_w + 'px'\n//上に戻る\n},w_c,'linear');\n});\n//up_t =　マーキー流れる時間とtopから降りてくる時間の合計\nvar up_t = w_c + 2600;\n//up_t経ったら上に戻る\nsetTimeout(function(){\nif(undefined !== fn){\nfn();\n}\n$('#Alert_Box').animate({\n'top':'-105%'\n},800)\n},up_t);\n}\n//------------------------------------------------------------\nfunction alert_slide_old( fn )\n{\nconsole.log('alert_slide');\nvar box_w =$('.Text_Mask').width();\nvar text_w = $('.Text').width();\nconsole.error('box_w: %s text_w: %s',box_w,text_w);\n//マーキーさせる秒数計算\nvar w_c = $('.Text').text().length;\nw_c = (w_c * 0.2) * 1500;\n$('.Text').fadeIn().delay(2000).animate({\n'left':'-' + text_w + 'px'\n},w_c,'linear',function( ev ){\nconsole.error('end');\nif(undefined !== fn){\nfn( ev );\n}\n});\n}\n//------------------------------------------------------------\nfunction remove_msg( msg_id, fn )\n{\nconsole.log('remove_msg(%s)',msg_id);\napi_nkfeed(api_url, 'delete', {msg_id: msg_id}, function(data){\nconsole.log('delete data: %O',data);\nif(undefined !== fn){\nfn();\n}\n});\n}\n//------------------------------------------------------------\nfunction api_nkfeed(url, action, ary_param, fn)\n{\nconsole.log('get_nkfeed(%s,%s,%O)',url,action,ary_param);\nvar _data = {};\n_data.input  = 'UTF-8';\n_data.output = 'jsonp';\n_data.action = action;\nfor(var key in ary_param){\n_data[key] = ary_param[key];\n}\n$.ajax({ type     : 'POST',\nurl      : url,\ndata     : _data,\ndataType : _data.output,\nsuccess  : function( json ){\nif(json.status == 'NG'){\nconsole.log('status:NG reason: %s',json.reason);\n}\nif(undefined != fn){\nfn( json );\n}\n},\nerror  : function(XMLHttpRequest, textStatus, errorThrown){\nconsole.log('XMLHttpRequest: %O',XMLHttpRequest);\nconsole.log('textStatus: %s',textStatus);\n}\n});\n}\n});\n</script>\n<div class=\"Contents\">\n<div class=\"Main_Column_mydata\">\n<!-- block=race_navi (d) -->\n<h2 class=\"Content_Title_Bar Content_Title_Bar_bet2\">今週のレース</h2>\n<div class=\"Race_Navi\">\n<div class=\"Main_Race\">\n<ul class=\"fc\">\n<li>\n<span id=\"navirac