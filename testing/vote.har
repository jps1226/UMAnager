          "content": {
            "size": 1322,
            "mimeType": "application/javascript",
            "text": "\n/*\n * $Id$\n *\n * ユーザー設定I/F\n *\n *  action \n *    'get': ユーザー設定情報を取得\n *    'set': ユーザー設定情報を更新\n *  ary_param\n *    action == 'get'時\n *       パラメータなし\n *    action == 'set'時\n *       bet_open      予想公開     'y':する 'n':しない\n *       feed_private  通知(自分)   'y':する 'n':しない\n *       feed_other    通知(その他) 'y':する 'n':しない\n *       sound         サウンド     'y':あり 'n':なし\n *       autobet       予想印の買い目作成   'y':あり(自動) 'n':なし(手動)\n *\n *    2017.10.13 Y.Shimizu\n *\n */\nfunction api_user_setting(url, action, ary_param, fn)\n{\n    console.log('api_user_setting(%s,%s,%O)',url,action,ary_param);\n\n    var _data = {};\n    _data.input  = 'UTF-8';\n    _data.output = 'jsonp';\n    _data.action = action;\n    for(var key in ary_param){\n\t_data[key] = ary_param[key];\n    }\n    $.ajax({ type     : 'POST',\n\t     url      : url,\n\t     data     : _data,\n\t     dataType : _data.output,\n\t     success  : function( json ){\n                 if(json.status == 'NG'){\n\t\t     console.log('status:NG reason: %s',json.reason);\n\t\t }\n\t\t if(undefined != fn){\n\t\t     fn( json );\n\t\t }\n\t     },\n\t     error  : function(XMLHttpRequest, textStatus, errorThrown){\n\t\t console.log('XMLHttpRequest: %O',XMLHttpRequest);\n\t\t console.log('textStatus: %s',textStatus);\n\t     }\n\t   });\n}\n\n"
          },
          "redirectURL": "",
