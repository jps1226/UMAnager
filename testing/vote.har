          "cookies": [],
          "content": {
            "size": 6787,
            "mimeType": "application/javascript",
            "text": "\n\"use strict\"\n\n/*\n * 投票済みの予想を取得する(json形式)\n */\nfunction get_bet(url, race_id, fn)\n{\n    console.log('get_bet(%s,%s)',url,race_id);\n\n    var _data = {};\n    _data.input  = 'UTF-8';\n    _data.output = 'jsonp';\n    _data.action = 'get';\n    _data.race_id = race_id;\n    $.ajax({ type     : 'POST',\n\t     url      : url,\n\t     data     : _data,\n\t     dataType : _data.output,\n\t     success  : function( json ){\n                 if(json.status == 'NG'){\n\t\t     console.log('status:NG reason: %s',json.reason);\n\t\t }\n\t\t if(undefined != fn){\n\t\t     fn( json );\n\t\t }\n\t     },\n\t     error  : function(XMLHttpRequest, textStatus, errorThrown){\n\t\t console.log('XMLHttpRequest: %O',XMLHttpRequest);\n\t\t console.log('textStatus: %s',textStatus);\n\t     }\n\t   });\n}\n\n/*\n * 予想投票を行う\n *   bet_type   'auto': 自動買い目発生\n *              'own' : 手動作成\n */\nfunction regist_bet(url, race_id, fn)\n{\n    console.log('regist_bet(%s,%s)',url,race_id);\n\n    var _data = {};\n    _data.input  = 'UTF-8';\n    _data.output = 'jsonp';\n    _data.action = 'update';\n    _data.race_id = race_id;\n    $.ajax({ type     : 'POST',\n\t     url      : url,\n\t     data     : _data,\n\t     dataType : _data.output,\n\t     success  : function( json ){\n                 if(json.status == 'NG'){\n\t\t     console.log('status:NG reason: %s',json.reason);\n                     switch(json.reason){\n                         case 'time over':\n                             swal('受付を終了しました：投票可能な時刻を過ぎているため、投票できませんでした。');\n                             return false;\n                         break;\n                         case 'price zero':\n                             swal('投票できませんでした：金額の合計が0円となっています。100円以上の金額に修正してください。');\n                             return false;\n                         break;\n                         case 'price over':\n                             swal('投票できませんでした：金額の合計が10,000円を超えています。10,000円を超えないように金額を修正してください。');\n                             return false;\n                         break;\n                         case 'prohibited race':\n                             swal('投票できませんでした：現在、このレースは一時的に投票を受け付けていません。しばらくしてから再度お試しください。');\n                             return false;\n                         break;\n                         case 'processing now':\n                             swal('投票処理中です：しばらくしてから再度お試しください。');\n                             return false;\n                         break;\n                         case 'betting error':\n                             swal('投票できませんでした：しばらくしてから再度お試しください。');\n                             return false;\n                         break;\n                         case 'ext price over':\n                             swal('投票できませんでした：金額の合計が上限を超えています。上限を超えないように金額を修正してください。');\n                             return false;\n                         break;\n                         case 'price shortage':\n                         case 'ext price shortage':\n                             swal('投票できませんでした：金額の合計が下限を下回っています。下限を下回らないように金額を修正してください。');\n                             return false;\n                         break;\n                         case 'ext tensuu over':\n                             swal('投票できませんでした：合計点数が上限を超えています');\n                             return false;\n                         break;\n                         case 'masters api error':\n                             swal('投票できませんでした：サービスに問題があります');\n                             return false;\n                         break;\n                         case 'invalid bet moeny':\n                             swal('投票できませんでした：投票金額に問題があります');\n                             return false;\n                         break;\n                         case 'masters other error':\n                             swal('投票できませんでした：投票が許可されていません');\n                             return false;\n                         break;\n                     }\n\t\t }\n\t\t if(undefined != fn){\n\t\t     fn( json );\n\t\t }\n\t     },\n\t     error  : function(XMLHttpRequest, textStatus, errorThrown){\n\t\t console.log('XMLHttpRequest: %O',XMLHttpRequest);\n\t\t console.log('textStatus: %s',textStatus);\n\t     }\n\t   });\n}\n\n/*\n * 勝負レース指定の予想を取得する\n */\nfunction get_bet_special(url, race_id, fn)\n{\n    console.log('get_bet_special(%s,%s)',url,race_id);\n\n    var _data = {};\n    _data.input  = 'UTF-8';\n    _data.output = 'jsonp';\n    _data.action = 'get';\n    _data.opt = 'special';\n    _data.race_id = race_id;\n    $.ajax({ type     : 'POST',\n\t     url      : url,\n\t     data     : _data,\n\t     dataType : _data.output,\n\t     success  : function( json ){\n                 if(json.status == 'NG'){\n\t\t     console.log('status:NG reason: %s',json.reason);\n\t\t }\n\t\t if(undefined != fn){\n\t\t     fn( json );\n\t\t }\n\t     },\n\t     error  : function(XMLHttpRequest, textStatus, errorThrown){\n\t\t console.log('XMLHttpRequest: %O',XMLHttpRequest);\n\t\t console.log('textStatus: %s',textStatus);\n\t     }\n\t   });\n}\n\n/*\n * 印から買い目を生成\n */\nfunction bet_generator(url, race_id, fn)\n{\n    console.log('bet_generator(%s,%s)',url,race_id);\n\n    var _data = {};\n    _data.input  = 'UTF-8';\n    _data.output = 'jsonp';\n    _data.race_id = race_id;\n    $.ajax({ type     : 'POST',\n\t     url      : url,\n\t     data     : _data,\n\t     dataType : _data.output,\n\t     success  : function( json ){\n                 if(json.status == 'NG'){\n\t\t     console.log('status:NG reason: %s',json.reason);\n\t\t }\n\t\t if(undefined != fn){\n\t\t     fn( json );\n\t\t }\n\t     },\n\t     error  : function(XMLHttpRequest, textStatus, errorThrown){\n\t\t console.log('XMLHttpRequest: %O',XMLHttpRequest);\n\t\t console.log('textStatus: %s',textStatus);\n\t     }\n\t   });\n}\n\n/*\n * 投票を馬券イメージに変換したHTMLを取得\n */\nfunction get_baken_image(url, race_id, src, fn)\n{\n    console.log('get_baken_image(%s,%s,%s)',url,race_id,src);\n\n    var _data = {};\n    _data.input  = 'UTF-8';\n    _data.output = 'jsonp';\n    _data.race_id = race_id;\n    _data.src = src;\n    $.ajax({ type     : 'POST',\n\t     url      : url,\n\t     data     : _data,\n\t     dataType : _data.output,\n\t     success  : function( json ){\n                 if(json.status == 'NG'){\n\t\t     console.log('status:NG reason: %s',json.reason);\n\t\t }\n\t\t if(undefined != fn){\n\t\t     fn( json );\n\t\t }\n\t     },\n\t     error  : function(XMLHttpRequest, textStatus, errorThrown){\n\t\t console.log('XMLHttpRequest: %O',XMLHttpRequest);\n\t\t console.log('textStatus: %s',textStatus);\n\t     }\n\t   });\n}\n"
          },
